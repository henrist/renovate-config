{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>henrist/renovate-config:automated"],
  "packageRules": [
    {
      "description": "Automerge all non-major updates",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    }
  ]
}
